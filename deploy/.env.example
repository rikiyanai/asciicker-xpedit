# Asciicker XP Editor — production environment
# Copy to .env and adjust for your deployment.

# Flask server bind address and port
PIPELINE_HOST=0.0.0.0
PIPELINE_PORT=5071
PIPELINE_DEBUG=false

# Gunicorn workers (rule of thumb: 2 * CPU cores + 1)
GUNICORN_WORKERS=3

# URL prefix for subpath hosting (empty = root-hosted).
# Example: PIPELINE_BASE_PATH=/xpedit
PIPELINE_BASE_PATH=

# Absolute path to the repo checkout on the server
APP_DIR=/opt/asciicker-pipeline-v2
