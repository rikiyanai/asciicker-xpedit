# Caddy reverse proxy for asciicker XP editor
#
# Usage:
#   caddy run --config deploy/Caddyfile
#
# Assumes the Flask app is running on 127.0.0.1:5071 via gunicorn.
# Replace xpedit.example.com with your actual domain.
#
# Two hosting modes are shown below. Enable ONE.

# ── Mode A: Subdomain / root hosting (PIPELINE_BASE_PATH="") ──
# The app owns the entire domain.

xpedit.example.com {
	reverse_proxy 127.0.0.1:5071

	# Optional: compression for JS/CSS/HTML assets
	encode gzip zstd

	# Optional: cache static runtime assets (WASM, data bundles)
	@runtime path /termpp-web/* /termpp-web-flat/*
	header @runtime Cache-Control "public, max-age=3600"
}

# ── Mode B: Subpath hosting (PIPELINE_BASE_PATH="/xpedit") ──
# The app lives under a prefix on a shared domain.
# Set PIPELINE_BASE_PATH=/xpedit in .env before starting the app.
#
# rikiworld.com {
# 	handle_path /xpedit/* {
# 		reverse_proxy 127.0.0.1:5071
# 	}
#
# 	# Other site content at /
# 	handle {
# 		root * /var/www/rikiworld
# 		file_server
# 	}
#
# 	encode gzip zstd
# }
