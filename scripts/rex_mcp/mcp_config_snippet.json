{
  "_comment": "Add these entries to .mcp.json mcpServers to enable REXPaint MCP tools",
  "rex-manager": {
    "command": "python3",
    "args": ["scripts/rex_mcp/server.py"],
    "env": {
      "WINE_PATH": "/path/to/wine",
      "REXPAINT_EXE_PATH": "/path/to/REXPaint.exe"
    }
  },
  "xp-tool": {
    "command": "python3",
    "args": ["scripts/xp_mcp_server.py"]
  }
}
